{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Simulation MAE (Clean vs Attacked)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "marl_sim_mae{disturbed=\"false\"}",
          "legendFormat": "Clean (seed {{seed}})",
          "refId": "A"
        },
        {
          "expr": "marl_sim_mae{disturbed=\"true\"}",
          "legendFormat": "Attacked (seed {{seed}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Simulation RMSE",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "marl_sim_rmse",
          "legendFormat": "seed={{seed}} disturbed={{disturbed}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Simulation MAPE",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "marl_sim_mape",
          "legendFormat": "{{seed}}/{{disturbed}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "min": 0 },
        "overrides": []
      }
    },
    {
      "title": "Worst-Case Error",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "marl_sim_worst_case",
          "legendFormat": "{{seed}}/{{disturbed}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Disturbance Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(marl_disturbance_success_total[5m]) / rate(marl_disturbance_injections_total[5m])",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      }
    },
    {
      "title": "Agent Delta Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "marl_agent_delta_bucket",
          "legendFormat": "{{actor}} ({{role}})",
          "refId": "A",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Round Latency Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(marl_game_round_latency_seconds_bucket[5m])",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Robustness Delta (Attacked MAE - Clean MAE)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "marl_sim_mae{disturbed=\"true\"} - marl_sim_mae{disturbed=\"false\"}",
          "legendFormat": "Delta (seed {{seed}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Game Rounds Total",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "marl_game_rounds_total",
          "legendFormat": "Total Rounds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Simulation Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "targets": [
        {
          "expr": "rate(marl_sim_duration_seconds_sum[5m]) / rate(marl_sim_duration_seconds_count[5m])",
          "legendFormat": "Avg Duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["marl", "simulation"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Simulation Metrics",
  "uid": "marl-sim-metrics"
}
