{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Ray Node Count",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "ray_cluster_active_nodes",
          "legendFormat": "Active Nodes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "CPU Utilization per Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "ray_node_cpu_utilization",
          "legendFormat": "{{NodeID}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": []
      }
    },
    {
      "title": "Memory Utilization per Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "ray_node_mem_used / ray_node_mem_total * 100",
          "legendFormat": "{{NodeID}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": []
      }
    },
    {
      "title": "Active / Completed / Failed Tasks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "ray_tasks{State=\"RUNNING\"}",
          "legendFormat": "Running",
          "refId": "A"
        },
        {
          "expr": "ray_tasks{State=\"FINISHED\"}",
          "legendFormat": "Completed",
          "refId": "B"
        },
        {
          "expr": "ray_tasks{State=\"FAILED\"}",
          "legendFormat": "Failed",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Actor Count by State",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "ray_actors",
          "legendFormat": "{{State}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ray", "cluster"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Ray Cluster Health",
  "uid": "marl-cluster-health"
}
